# ============================================================
# Trader_IA — Template .env pour le VPS Hostinger
# Copier ce fichier en .env puis compléter chaque valeur.
# NE JAMAIS COMMIT LE .env RÉEL.
# ============================================================

# --- Traefik / TLS -------------------------------------------
SSL_EMAIL=you@example.com
GENERIC_TIMEZONE=Europe/Paris

# --- Domain n8n ----------------------------------------------
SUBDOMAIN=n8n
DOMAIN_NAME=example.com
# URL publique finale: https://${SUBDOMAIN}.${DOMAIN_NAME}

# --- n8n task runners ----------------------------------------
# Doit être identique entre le service n8n et les task-runners.
# Générer une valeur forte: `openssl rand -hex 32`
N8N_RUNNERS_AUTH_TOKEN=replace_me_with_a_strong_random_value

# --- Qdrant (déployé via docker-compose.qdrant.yml) ----------
QDRANT_API_KEY=replace_me_with_a_strong_random_value

# --- Transcript API (service externe) ------------------------
TRANSCRIPT_API_BASE=https://transcript.example.com

# --- Google Sheets (dashboard / legacy) ----------------------
GOOGLE_SHEET_ID=1AbCDeFGhIjKlMnOpQrStUvWxYz

# --- Trading dashboard (Streamlit) ---------------------------
DASHBOARD_DOMAIN=dashboard.example.com
# Hash Basic Auth pour Traefik middleware.
# Générer: `htpasswd -nb admin 'motdepasse' | sed -e s/\\$/\\$\\$/g`
DASHBOARD_BASIC_AUTH=admin:$$apr1$$xxxxxxxx$$yyyyyyyyyyyyyyyyyyyyy
